# Copy to .env and fill in with your secrets before running the server

# LLM Provider Configuration
# Set to 'ollama' to use local Ollama, or 'huggingface' to use HuggingFace API
LLM_PROVIDER=ollama

# HuggingFace Configuration (only needed if LLM_PROVIDER=huggingface)
HF_API_KEY=hf_your_token_here

# Ollama Configuration (only needed if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Server Configuration
APP_SHARED_PASSWORD=                 # optional, remove or leave blank to disable
PORT=3001
